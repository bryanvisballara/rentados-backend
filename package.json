{
  "name": "rentados-backend",
  "version": "0.1.0",
  "description": "API backend para Rentados — administración de conjuntos residenciales",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dev:web": "npm --prefix web run dev",
    "dev:all": "concurrently -n api,web -c green,cyan \"npm run dev\" \"npm run dev:web\"",
    "seed": "node src/scripts/seed.js",
    "sync:unit-codes": "node src/scripts/sync-unit-codes.js",
    "db:sync": "node src/scripts/seed.js",
    "build:web": "npm --prefix web run build",
    "postbuild": "node scripts/postbuild.js",
    "deploy:render": "node scripts/trigger-render-deploy.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "rentados",
    "property-management",
    "mongodb"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.15.1",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
