NODE_ENV=development
PORT=3000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/rentados?retryWrites=true&w=majority
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d
CORS_ORIGIN=http://localhost:5174

# Cloudinary (publicaciones y casillero — imágenes optimizadas)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Alternativa: CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Render / producción
RUN_DB_SYNC=false
DEPLOY_KEY=genera-un-secreto-largo-para-sync-remoto
RENDER_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-XXXXXXXX?key=XXXXXXXX
